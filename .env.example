# Server-only secrets. Do not prefix either value with NEXT_PUBLIC_.
DATABASE_URL=postgresql://postgres:password@localhost:5432/cardkeeper
DATABASE_MAX_CONNECTIONS=1
POKEMON_TCG_API_KEY=

# Optional eBay Browse API listings. Use production in Vercel once approved;
# sandbox is useful for credentials smoke checks but returns mock/limited data.
EBAY_ENVIRONMENT=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_REQUEST_TIMEOUT_MS=1500

# Optional production hardening. If unset, API rate limiting falls back to
# per-runtime in-memory buckets, which is fine for local/dev but not distributed.
RATE_LIMIT_REDIS_REST_URL=
RATE_LIMIT_REDIS_REST_TOKEN=
RATE_LIMIT_REDIS_KEY_PREFIX=cardkeeper
SERVER_SLOW_OPERATION_MS=1000
DATABASE_SLOW_QUERY_MS=750

# Supabase project values. These two values are intentionally available to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Playwright test account for authenticated e2e coverage.
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_PASSWORD=
